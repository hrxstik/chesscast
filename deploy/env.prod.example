# Скопируйте в корень репозитория как .env.prod
# docker compose --env-file .env.prod -f docker-compose.prod.yml ...

# --- Домен / SSL ---
DOMAIN=chesscast.example.com
CERT_NAME=chesscast.example.com
CERT_EMAIL=admin@example.com
# CERT_STAGING=1   # тестовый сертификат Let's Encrypt

# Публичный IP VPS (для WebRTC / mediasoup)
MEDIASOUP_ANNOUNCED_IP=203.0.113.10
MEDIASOUP_UDP_PORT_MIN=40000
MEDIASOUP_UDP_PORT_MAX=40100

# --- PostgreSQL ---
POSTGRES_USER=chesscast
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=chesscast

# --- Redis ---
REDIS_PWD=change_me_redis

# --- Elasticsearch ---
ELASTIC_PASSWORD=change_me_elastic
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- Backend (секреты) ---
JWT_SECRET_KEY=change_me_jwt_min_32_chars

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# В кабинете ЮKassa webhook: https://DOMAIN/api/payments/yookassa/webhook

# DISABLE_SUBSCRIPTION_RENEWAL_CRON=true
