# Скопируйте в .env и заполните. Тестовый магазин и секрет: личный кабинет ЮKassa → Настройки → Ключи API.

# --- ЮKassa (тест) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Куда вернётся пользователь после оплаты (должен совпадать с разрешёнными URL в настройках магазина ЮKassa)
YOOKASSA_RETURN_URL=http://localhost:3000/dashboard/profile?payment=success
# Базовый URL фронта (если не задан YOOKASSA_RETURN_URL)
FRONTEND_URL=http://localhost:3000

# URL уведомлений в личном кабинете ЮKassa укажите вручную, например:
# https://<ваш-ngrok>/api/payments/yookassa/webhook
