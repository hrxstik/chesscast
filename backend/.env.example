# Скопируйте в backend/.env и заполните.
# Локальный стек: postgres + redis + docker-compose.elasticsearch.yml

# --- HTTP API ---
PORT=5000
HOSTNAME=0.0.0.0

# --- HTTPS (локально + доступ по IP в LAN) ---
# 1) Установите mkcert, в корне репозитория:
#    mkcert -install
#    mkcert localhost 127.0.0.1 192.168.X.X
# 2) Раскомментируйте:
# USE_HTTPS=true
# SSL_CERT_PATH=../localhost+2.pem
# SSL_KEY_PATH=../localhost+2-key.pem
# На телефоне/другом ПК: установить root CA mkcert (%LOCALAPPDATA%\mkcert\rootCA.pem)

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://chesscast:chesscast@127.0.0.1:5432/chesscast?schema=public

# --- JWT ---
JWT_SECRET_KEY=change_me_min_32_random_chars

# --- Фронт (редиректы после оплаты, CORS-контекст) ---
FRONTEND_URL=http://localhost:3000

# --- ЮKassa (тестовый магазин: личный кабинет → Настройки → Ключи API) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/dashboard/profile?payment=success
# Webhook в кабинете ЮKassa (ngrok / прод):
# https://<host>/api/payments/yookassa/webhook

# --- Redis (BullMQ: автопродление подписок, переиндексация ES) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PWD=
# DISABLE_SUBSCRIPTION_RENEWAL_CRON=true

# --- Elasticsearch (docker-compose.elasticsearch.yml) ---
ELASTICSEARCH_NODE=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=chesscast_es_dev
# Самоподписанный сертификат в Docker:
ELASTICSEARCH_TLS_INSECURE=true

# --- WebRTC / mediasoup (публичный IP на VPS, 127.0.0.1 локально) ---
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# --- Распознавание доски (Python worker) ---
# Путь к каталогу chess-recognition в репозитории
CHESS_RECOGNITION_DIR=../chess-recognition
PYTHON_BIN=python
# Опционально: абсолютные пути к весам
# YOLO_MODEL_PATH=
# CORNER_MODEL_PATH=
