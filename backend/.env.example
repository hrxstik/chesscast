HOSTNAME=0.0.0.0
PORT=5000

# HTTPS для LAN (камера/WebRTC). Сертификат mkcert с вашим IP:
# USE_HTTPS=true
# SSL_CERT_PATH=../localhost+3.pem
# SSL_KEY_PATH=../localhost+3-key.pem

USE_HTTPS=true
SSL_CERT_PATH=../localhost+3.pem
SSL_KEY_PATH=../localhost+3-key.pem

LAN_IP=

DATABASE_URL=postgresql://chesscast:chesscast@127.0.0.1:5432/chesscast?schema=public

JWT_SECRET_KEY=change_me_min_32_random_chars
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=30d

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

ELASTICSEARCH_NODE=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=chesscast_es_dev
ELASTICSEARCH_TLS_INSECURE=true

MEDIASOUP_ANNOUNCED_IP=127.0.0.1

CHESS_RECOGNITION_DIR=../chess-recognition
# CV worker: Python 3.12 venv в chess-recognition/.venv (см. README). Если пусто — подставится venv автоматически.
# PYTHON_BIN=../chess-recognition/.venv/Scripts/python.exe
# HAND_LANDMARKER_MODEL=../chess-recognition/models/hand_landmarker.task

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# FRONTEND_URL / MEDIASOUP / YOOKASSA_RETURN_URL — scripts/lan-env.mjs при npm run start:dev
