generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  email        String       @unique
  password     String?
  avatar       String       @default("default.png")
  platformRole PlatformRole @default(USER)
  blocked      Boolean      @default(false)
  blockedReason String?

  subscriptions      Subscription[]
  userGames          UserGame[]
  userOrganizations  UserOrganization[]
  gamesCreated       Game[]             @relation("GameCreator")
  payments           Payment[]
  billingEventsActed BillingEvent[]     @relation("BillingEventActor")
  organizationsOwned Organization[]     @relation("OrganizationOwner")

  verified   DateTime?
  provider   String?
  providerId String?

  verificationCodes VerificationCode[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  code      String
  createdAt DateTime @default(now())

  @@unique([userId, code])
}

model Organization {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String
  avatar      String @default("default.png")

  blocked Boolean @default(false)
  blockedReason String?
  ownerUserId Int
  owner      User @relation("OrganizationOwner", fields: [ownerUserId], references: [id])

  games Game[]
  users UserOrganization[]

  inviteCode String @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Game {
  id Int @id @default(autoincrement())

  mode   GameMode
  result GameResult
  status GameStatus @default(PENDING)
  users  UserGame[]

  token          String        @unique
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?

  visibility GameVisibility @default(PRIVATE)
  creator    User?          @relation("GameCreator", fields: [creatorId], references: [id])
  creatorId  Int?

  initialPosition String   @default("startpos")
  moves           String[] @default([])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model UserGame {
  user   User @relation(fields: [userId], references: [id])
  userId Int

  game   Game @relation(fields: [gameId], references: [id])
  gameId Int

  color Color

  @@id([userId, gameId])
}

model UserOrganization {
  user   User @relation(fields: [userId], references: [id])
  userId Int

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int

  role Role

  @@id([userId, organizationId])
}

enum Color {
  WHITE
  BLACK
}

enum Role {
  PLAYER
  ADMIN
}

enum PlatformRole {
  USER
  SUPERADMIN
}

enum GameVisibility {
  PRIVATE
  PUBLIC
}

enum GameResult {
  WHITE_WIN
  WHITE_LOSE
  BLACK_WIN
  BLACK_LOSE
  WHITE_RESIGN
  BLACK_RESIGN
  WHITE_TIME_OUT
  BLACK_TIME_OUT
  STALEMATE
  DRAW
  CANCELLED
}

enum GameMode {
  TRAINING
  COMPETITIVE
}

enum GameStatus {
  PENDING
  IN_PROGRESS
  FINISHED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELLED
  REFUNDED
}

enum PaymentPurpose {
  SUBSCRIPTION_PERSONAL
  OTHER
}

enum BillingEventType {
  INVOICE_PAID
  REFUND
  CHARGEBACK
  MANUAL_ADJUSTMENT
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PAUSED
}

enum StreamQualityLevel {
  LOW
  MEDIUM
  HIGH
}

model Plan {
  id                    Int                @id @default(autoincrement())
  code                  String             @unique
  title                 String
  description           String             @default("")
  features              String[]           @default([])
  maxGamesPerPeriod     Int
  maxOrganizations      Int
  canCreateOrganization Boolean
  canStream             Boolean
  streamQualityLevel    StreamQualityLevel
  priceMonthly          Decimal            @db.Decimal(12, 2)
  currency              String             @default("RUB")
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id         Int                @id @default(autoincrement())
  userId     Int
  user       User               @relation(fields: [userId], references: [id])
  planId     Int
  plan       Plan               @relation(fields: [planId], references: [id])
  status     SubscriptionStatus
  startAt    DateTime
  endAt      DateTime
  autoRenew  Boolean            @default(false)
  canceledAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  payments Payment[]
}

model Payment {
  id                Int            @id @default(autoincrement())
  userId            Int
  user              User           @relation(fields: [userId], references: [id])
  subscriptionId    Int
  subscription      Subscription   @relation(fields: [subscriptionId], references: [id])
  planId            Int
  plan              Plan           @relation(fields: [planId], references: [id])
  providerPaymentId String?        @unique
  amount            Decimal        @db.Decimal(12, 2)
  currency          String         @default("RUB")
  status            PaymentStatus
  purpose           PaymentPurpose
  metadata          Json?
  createdAt         DateTime       @default(now())
  billingEvents     BillingEvent[]
}

model BillingEvent {
  id          Int              @id @default(autoincrement())
  type        BillingEventType
  amount      Decimal?         @db.Decimal(12, 2)
  currency    String?          @default("RUB")
  paymentId   Int?
  payment     Payment?         @relation(fields: [paymentId], references: [id])
  actorUserId Int?
  actor       User?            @relation("BillingEventActor", fields: [actorUserId], references: [id])
  metadata    Json?
  createdAt   DateTime         @default(now())
}
